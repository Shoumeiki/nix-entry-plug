*.agekey
*.age
secrets/*.key
secrets/keys.txt
secrets/age/

# Local env files
.env
.env.*

# Phase 0 migration artefacts (reference only, not part of the config)
pkglist.txt
dotfiles-backup/

# nix-index / nix REPL state
.nix-repl-history

# pre-commit local state
.pre-commit-config.yaml.bak
